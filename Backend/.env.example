# ── Database (Supabase Postgres) ────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL = the POOLED (Supavisor / "Transaction") connection, port 6543.
#   Used by the running app. Append ?pgbouncer=true&connection_limit=1
# DIRECT_URL   = the DIRECT connection, port 5432. Used by `prisma migrate`.
#
# Replace [YOUR-DB-PASSWORD] with your database password (Project Settings → Database).
DATABASE_URL="postgresql://postgres.lezpnfelybhztkcivtam:[YOUR-DB-PASSWORD]@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.lezpnfelybhztkcivtam:[YOUR-DB-PASSWORD]@aws-0-<REGION>.pooler.supabase.com:5432/postgres"

# ── Supabase Auth (JWT verification) ────────────────────────────────────────
SUPABASE_URL="https://lezpnfelybhztkcivtam.supabase.co"
SUPABASE_PROJECT_ID="lezpnfelybhztkcivtam"
# Anon/publishable key (public) — enables remote token validation as a fallback,
# so auth works regardless of the project's JWT signing scheme.
SUPABASE_ANON_KEY="<your-supabase-anon-or-publishable-key>"
# The JWKS endpoint is derived from SUPABASE_URL; no service-role key is required
# for verifying user JWTs. (Service-role key only needed for admin operations.)
#
# OPTIONAL legacy fallback: if your Supabase project still signs JWTs with the
# legacy HS256 shared secret (Project Settings → API → JWT Settings → JWT Secret),
# set it here. Leave it UNSET to use the recommended asymmetric JWKS verification.
# SUPABASE_JWT_SECRET=""

# ── App ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Comma-separated list of allowed origins for CORS (the Next.js frontend)
CORS_ORIGINS="http://localhost:3000"

# ── Optional integrations ───────────────────────────────────────────────────
# Service-role key (Project Settings → API). Enables inviting NEW users by email.
# Leave unset to disable invites (existing-member management still works).
# SUPABASE_SERVICE_ROLE_KEY=""
# Storage bucket name for document uploads (create it in Supabase → Storage).
# DOCUMENTS_BUCKET="documents"
# Sentry error tracking — leave unset to disable.
# SENTRY_DSN=""
